# ============================================================
# CREDENCIAIS - copie este arquivo para .env e preencha
# ============================================================

# --- PIPEFY ---
# Gerar em: app.pipefy.com → Perfil → Tokens de API
PIPEFY_TOKEN=seu_personal_access_token_aqui

# --- SUPABASE ---
# Encontrar em: supabase.com → Seu projeto → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Encontrar em: supabase.com → Seu projeto → Project Settings → General
SUPABASE_PROJECT_REF=xxxxxxxxxxxxxxxxxxxx

# Opcional: para o script criar tabela e fazer deploy da Edge Function automaticamente.
# Gerar em: supabase.com/dashboard/account/tokens (Personal Access Token)
# Se não definir, o passo 2 pode retornar 401; você pode criar tabela e deploy manualmente.
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxx

# --- PIPEFY PIPE IDs ---
# Preencher APÓS rodar o script 1_discover_pipefy.py
PIPE_ID_COMERCIAL=
PIPE_ID_COMPLIANCE=
PIPE_ID_JURIDICO=
PIPE_ID_FINANCEIRO=
